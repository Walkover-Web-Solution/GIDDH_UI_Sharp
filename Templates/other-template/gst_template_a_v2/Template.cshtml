                                          </td>
                                       }
                                       @if (HasKey(Model?.label, "hsnSac") && !string.IsNullOrEmpty(Model?.label?.hsnSac?.ToString()))
                                       {
                                          @if (HasKey(tr, "hsnNumber") && !string.IsNullOrEmpty(tr?.hsnNumber?.ToString()) && HasKey(tr, "sacNumber") && !string.IsNullOrEmpty(tr?.sacNumber?.ToString()))
                                          {
                                             @if (HasKey(Model, "manageInventory") && Model?.manageInventory == true)
                                             {
                                                @if (HasKey(tr, "hsnNumber") && !string.IsNullOrEmpty(tr?.hsnNumber?.ToString()))
                                                {
                                                   <td class="text-right">@tr?.hsnNumber<small> (H)</small></td>
                                                }
                                             }
                                             else if (HasKey(tr, "sacNumber") && !string.IsNullOrEmpty(tr?.sacNumber?.ToString()))
                                             {
                                                <td class="text-right">@tr?.sacNumber<small>(S)</small></td>
                                             }
                                             else
                                             {
                                                <td></td>
                                             }
                                          }
                                          else if (HasKey(tr, "hsnNumber") && !string.IsNullOrEmpty(tr?.hsnNumber?.ToString()))
                                          {
                                             <td class="text-right">@tr?.hsnNumber<small> (H)</small></td>
                                          }
                                          else if (HasKey(tr, "sacNumber") && !string.IsNullOrEmpty(tr?.sacNumber?.ToString()))
                                          {
                                             <td class="text-right">@tr?.sacNumber<small>(S)</small></td>
                                          }
                                          else
                                          {
                                             <td></td>
                                          }
                                       }
                                       @if (HasKey(Model?.label, "quantity") && !string.IsNullOrEmpty(Model?.label?.quantity?.ToString()))
                                       {
                                          <td class="text-right">@if (HasKey(tr, "quantity") && tr?.quantity != null) { @tr?.quantity @(HasKey(tr, "stockUnit") ? tr?.stockUnit : "") }</td>
                                       }
                                       @if (HasKey(Model?.label, "rate") && !string.IsNullOrEmpty(Model?.label?.rate?.ToString()))
                                       {
                                          <td class="text-right">@if (HasKey(tr, "rate") && tr?.rate != null) { @tr?.rate }</td>
                                       }
                                       @if (HasKey(Model?.label, "discount") && !string.IsNullOrEmpty(Model?.label?.discount?.ToString()) && (HasKey(entry, "discounts") && (entry?.discounts == null || entry?.discounts.Count < 1)))
                                       {
                                          <td class="text-right"></td>
                                       }
                                       @if (HasKey(entry, "discounts") && entry?.discounts != null)
                                       {
                                          @foreach (var discount in entry?.discounts)
                                          {
                                             @if (HasKey(tr, "category") && tr?.category != category)
                                             {
                                                <td class="text-right">@((decimal)(HasKey(discount, "amount") ? discount?.amount ?? 0 : 0) * -1)</td>
                                                distTotal = distTotal + (decimal)(HasKey(discount, "amount") ? discount?.amount ?? 0 : 0);
                                             }
                                             else
                                             {
                                                <td></td>
                                             }
                                          }
                                       }
                                       @if (HasKey(Model?.label, "taxableValue") && !string.IsNullOrEmpty(Model?.label?.taxableValue?.ToString()))
                                       {
                                          @if (HasKey(tr, "category") && tr?.category != category)
                                          {
                                             <td class="text-right">@((HasKey(tr, "amount") ? tr?.amount ?? 0 : 0) - distTotal)</td>
                                          }
                                          else
                                          {
                                             <td></td>
                                          }
                                       }
                                       @if (HasKey(Model?.label, "taxes") && !string.IsNullOrEmpty(Model?.label?.taxes?.ToString()))
                                       {
                                          @if (HasKey(Model, "gstTaxesTotal") && Model?.gstTaxesTotal != null)
                                          {
                                             @foreach (var taxWithTotal in Model?.gstTaxesTotal)
                                             {
                                                int foundTax = 0;
                                                decimal tempTax = 0;
                                                decimal taxRate = 0;
                                                if (HasKey(entry, "taxes") && entry?.taxes != null)
                                                {
                                                   foreach (var tax in entry?.taxes)
                                                   {
                                                      if (HasKey(taxWithTotal, "uniqueName") && HasKey(tax, "accountUniqueName") && taxWithTotal?.uniqueName == tax?.accountUniqueName)
                                                      {
                                                         foundTax = 1;
                                                         tempTax = (decimal)(HasKey(tax, "amount") ? tax?.amount ?? 0 : 0);
                                                         taxRate = (decimal)(HasKey(tax, "rate") ? tax?.rate ?? 0 : 0);
                                                         txTotal = txTotal + tempTax;
                                                      }
                                                   }
                                                }
                                                @if (foundTax == 1 && HasKey(tr, "category") && tr?.category != category)
                                                {
                                                   <td class="text-right">
                                                      @tempTax
                                                      <br/>
                                                      <p>@@@taxRate%</p>
                                                   </td>
                                                }
                                                else
                                                {
                                                   <td class="text-right"></td>
                                                }
                                             }
                                          }
                                       }
                                       @if (HasKey(Model?.label, "total") && !string.IsNullOrEmpty(Model?.label?.total?.ToString()))
                                       {
                                          @if (HasKey(tr, "category") && tr?.category != category)
                                          {
                                             txTotal = (HasKey(tr, "amount") ? tr?.amount ?? 0 : 0) + txTotal - distTotal;
                                             <td colspan="2" class="text-right">@txTotal</td>
                                          }
                                          else
                                          {
                                             <td colspan="2" class="text-right">@(HasKey(tr, "amount") ? tr?.amount : "")</td>
                                          }
                                       }
                                    </tr>
                                 }
                              }
                           }
                        }
                     </tbody>
                     @if (tableCount == (Model?.entries?.Count ?? 0))
                     {
                        <tfoot>
                           <tr class="font-normal">
                              @if (HasKey(Model?.label, "sNo") && !string.IsNullOrEmpty(Model?.label?.sNo?.ToString()))
                              {
                                 <th class="text-left" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "date") && !string.IsNullOrEmpty(Model?.label?.date?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "item") && !string.IsNullOrEmpty(Model?.label?.item?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "hsnSac") && !string.IsNullOrEmpty(Model?.label?.hsnSac?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "quantity") && !string.IsNullOrEmpty(Model?.label?.quantity?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "rate") && !string.IsNullOrEmpty(Model?.label?.rate?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "discount") && !string.IsNullOrEmpty(Model?.label?.discount?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "taxableValue") && !string.IsNullOrEmpty(Model?.label?.taxableValue?.ToString()))
                              {
                                 <th class="text-right">@(HasKey(Model, "taxableTotal") ? Model?.taxableTotal : "")</th>
                              }
                              @if (HasKey(Model?.label, "taxes") && !string.IsNullOrEmpty(Model?.label?.taxes?.ToString()))
                              {
                                 @if (HasKey(Model, "gstTaxesTotal") && Model?.gstTaxesTotal != null)
                                 {
                                    @foreach (var taxWithTotal in Model?.gstTaxesTotal)
                                    {
                                       <th class="text-right">@(HasKey(taxWithTotal, "total") ? taxWithTotal?.total : "")</th>
                                    }
                                 }
                              }
                              @if (HasKey(Model?.label, "total") && !string.IsNullOrEmpty(Model?.label?.total?.ToString()))
                              {
                                 <th class="text-right" colspan="2">@(HasKey(Model, "gstEntriesTotal") ? Model?.gstEntriesTotal : "")</th>
                              }
                           </tr>
                        </tfoot>
                     }
                     else
                     {
                        <tfoot>
                           <tr>
                              @if (HasKey(Model?.label, "sNo") && !string.IsNullOrEmpty(Model?.label?.sNo?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "date") && !string.IsNullOrEmpty(Model?.label?.date?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "item") && !string.IsNullOrEmpty(Model?.label?.item?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "hsnSac") && !string.IsNullOrEmpty(Model?.label?.hsnSac?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "quantity") && !string.IsNullOrEmpty(Model?.label?.quantity?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "rate") && !string.IsNullOrEmpty(Model?.label?.rate?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "discount") && !string.IsNullOrEmpty(Model?.label?.discount?.ToString()))
                              {
                                 <th class="text-right" style="white-space: normal !important;"></th>
                              }
                              @if (HasKey(Model?.label, "taxableValue") && !string.IsNullOrEmpty(Model?.label?.taxableValue?.ToString()))
                              {
                                 <th class="text-right"></th>
                              }
                              @if (HasKey(Model?.label, "taxes") && !string.IsNullOrEmpty(Model?.label?.taxes?.ToString()))
                              {
                                 @if (HasKey(Model, "gstTaxesTotal") && Model?.gstTaxesTotal != null)
                                 {
                                    @foreach (var taxWithTotal in Model?.gstTaxesTotal)
                                    {
                                       <th class="text-right"></th>
                                    }
                                 }
                              }
                              @if (HasKey(Model?.label, "total") && !string.IsNullOrEmpty(Model?.label?.total?.ToString()))
                              {
                                 <th class="text-right" colspan="2"></th>
                              }
                           </tr>
                        </tfoot>
                     }
                  </table>
                  @if (tableCount != (Model?.entries?.Count ?? 0))
                  {
                     <div style="float:right; margin:20px; font-size: 14px; ">
                        <strong>Continued...</strong>
                     </div>
                  }
               </article>
            </div>
            @if (tableCount == (Model?.entries?.Count ?? 0))
            {
               <div style="width: 100%; display: block; float: none; overflow: hidden;">
                  <table class="balance" style="">
                     @if (HasKey(Model?.label, "taxableAmount") && !string.IsNullOrEmpty(Model?.label?.taxableAmount?.ToString()))
                     {
                        <tr>
                           <th>
                              @Model?.label?.taxableAmount
                           </th>
                           <td>
                              @Model?.taxableAmount
                           </td>
                        </tr>
                     }
                     @if (HasKey(Model?.label, "totalTax") && !string.IsNullOrEmpty(Model?.label?.totalTax?.ToString()))
                     {
                        <tr>
                           <th>
                              <strong>@Model?.label?.totalTax</strong>
                           </th>
                           <td>
                              <strong>@(HasKey(Model, "totalTax") ? Model?.totalTax : "")</strong>
                           </td>
                        </tr>
                     }
                     @if (HasKey(Model, "commonDiscountEntries") && Model?.commonDiscountEntries != null)
                     {
                        @foreach (var commonDiscountEntry in Model?.commonDiscountEntries)
                        {
                           <tr>
                              <th>
                                 @(HasKey(commonDiscountEntry, "accountName") ? commonDiscountEntry?.accountName : "")
                              </th>
                              <td>
                                 @(HasKey(commonDiscountEntry, "amount") ? commonDiscountEntry?.amount : "")
                              </td>
                           </tr>
                        }
                     }
                     @if (HasKey(Model, "otherDiscount") && !string.IsNullOrEmpty(Model?.otherDiscount?.ToString()))
                     {
                        <tr>
                           <th>Trade Discount</th>
                           <td>@Model?.otherDiscount</td>
                        </tr>
                     }
                     @if (HasKey(Model, "roundOff") && !string.IsNullOrEmpty(Model?.roundOff?.ToString()))
                     {
                        <tr>
                           <th>
                              Round Off
                           </th>
                           <td>
                              @Model?.roundOff
                           </td>
                        </tr>
                     }
                     @if (HasKey(Model?.label, "grandTotal") && !string.IsNullOrEmpty(Model?.label?.grandTotal?.ToString()))
                     {
                        <tr>
                           <th>
                              @Model?.label?.grandTotal @if (HasKey(Model, "currency") && !string.IsNullOrEmpty(Model?.currency?.ToString())) { <text>(@Model?.currency)</text> }
                           </th>
                           <td>
                              @Model?.grandTotal
                           </td>
                        </tr>
                     }
                     @if (HasKey(Model, "paidAmount") && (Model?.paidAmount ?? 0) > 0)
                     {
                        <tr>
                           <th>
                              Paid
                           </th>
                           <td>
                              @Model?.paidAmount
                           </td>
                        </tr>
                        <tr>
                           <th>
                              Due Amount
                           </th>
                           <td>
                              @Model?.balance
                           </td>
                        </tr>
                     }
                     @if (HasKey(Model?.label, "totalInWords") && !string.IsNullOrEmpty(Model?.label?.totalInWords?.ToString()))
                     {
                        <tr>
                           <th>
                              @Model?.label?.totalInWords
                           </th>
                           <td>
                              @Model?.totalInWords
                           </td>
                        </tr>
                     }
                     @if (HasKey(Model?.label, "totalDue") && !string.IsNullOrEmpty(Model?.label?.totalDue?.ToString()) && HasKey(Model, "totalDue") && !string.IsNullOrEmpty(Model?.totalDue?.ToString()))
                     {
                        <tr>
                           <th>
                              Total Due
                           </th>
                           <td>
                              @Model?.totalDue
                           </td>
                        </tr>
                     }
                  </table>
               </div>
            }
            <div id="Template-footer" class="sadik">
               <table cellpadding="0" cellspacing="0" class="subfooter" style="text-align: left;height: auto;vertical-align: top; display: block; clear:both; float: none; overflow: hidden; padding-bottom: 15px;">
                  <tbody>
                     <tr>
                        <td style="text-align:left; padding-left: 15px; width: 37%;">
                           @if (tableCount == (Model?.entries?.Count ?? 0))
                           {
                              <div>
                                 @if (HasKey(Model, "message1") && !string.IsNullOrEmpty(Model?.message1?.ToString()))
                                 {
                                    <p>@Model?.message1</p>
                                    @if (HasKey(Model, "message2") && !string.IsNullOrEmpty(Model?.message2?.ToString()))
                                    {
                                       <p>@Model?.message2</p>
                                    }
                                 }
                                 @if (HasKey(Model, "name") && !string.IsNullOrEmpty(Model?.name?.ToString()))
                                 {
                                    <p> Name : @Model?.name</p>
                                 }
                                 @if (HasKey(Model, "virtualBankAcc") && !string.IsNullOrEmpty(Model?.virtualBankAcc?.ToString()))
                                 {
                                    <p>A/C No : @Model?.virtualBankAcc</p>
                                 }
                                 @if (HasKey(Model, "ifscCode") && !string.IsNullOrEmpty(Model?.ifscCode?.ToString()))
                                 {
                                    <p> Ifsc : @Model?.ifscCode</p>
                                 }
                              </div>
                              <section>
                              </section>
                           }
                           <h4 style="font-weight: bold !important; font-size: 14px;">@if (HasKey(Model, "thanks") && Model?.thanks == true) { <text>Thank you for your business</text> }</h4>
                        </td>
                        @if (HasKey(Model, "sealPath") && !string.IsNullOrEmpty(Model?.sealPath?.ToString()))
                        {
                           <td >
                              <img height="120px" width="220px" src="@Model?.sealPath" align="left" />
                           </td>
                        }
                        <td style="vertical-align: bottom; width:30%">
                           <div class="signature" style="text-align: center;width: 100%;
                              display: block;
                              clear: both;
                              float: none;">
                              <hr/>
                              <p style="word-wrap: break-word;overflow-wrap: break-word;">
                                 <strong class="font-10">@if (HasKey(Model, "companyName") && !string.IsNullOrEmpty(Model?.companyName?.ToString())) { <text>@Model?.companyName</text> }</strong>
                              </p>
                              @if (HasKey(Model?.label, "imageSignature") && !string.IsNullOrEmpty(Model?.label?.imageSignature?.ToString()))
                              {
                                 @if (HasKey(Model, "imageSignature") && !string.IsNullOrEmpty(Model?.imageSignature?.ToString()))
                                 {
                                    <img src="@Model?.imageSignature" width="150" height="100" />
                                 }
                              }
                              <h3>@if (HasKey(Model, "slogan") && !string.IsNullOrEmpty(Model?.slogan?.ToString())) { <text>@Model?.slogan</text> }</h3>
                           </div>
                        </td>
                     </tr>
                  </tbody>
               </table>
               <footer style="text-align: center;">
                  <p>
                     <strong class="font-10">@if (HasKey(Model, "companyName") && !string.IsNullOrEmpty(Model?.companyName?.ToString())) { <text>@Model?.companyName</text> }</strong>
                  </p>
                  <p class="font-10">
                     @if (HasKey(Model, "companyAddress") && Model?.companyAddress != null)
                     {
                        @foreach (var address in Model?.companyAddress)
                        {
                           @if (!string.IsNullOrEmpty(address?.ToString()))
                           {
                              <p>@address</p>
                           }
                        }
                     }
                  </p>
               </footer>
            </div>
            @if (tableCount != (Model?.entries?.Count ?? 0))
            {
               <div class="page"></div>
            }
         </div>
         }
      }
   </body>
</html>
