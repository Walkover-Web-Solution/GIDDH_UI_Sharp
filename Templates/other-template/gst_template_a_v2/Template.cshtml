                           <tr>
                              @if ((HasKey(Model, "customerName") && !string.IsNullOrEmpty(Model?.customerName?.ToString())) || (HasKey(Model, "customerEmail") && !string.IsNullOrEmpty(Model?.customerEmail?.ToString())) || (HasKey(Model, "customerMobileNumber") && !string.IsNullOrEmpty(Model?.customerMobileNumber?.ToString())) || (HasKey(Model, "attentionTo") && !string.IsNullOrEmpty(Model?.attentionTo?.ToString())))
                              {
                                 <td>
                                    @if (HasKey(Model, "attentionTo") && !string.IsNullOrEmpty(Model?.attentionTo?.ToString()))
                                    {
                                       <p>
                                          <strong>@Model?.attentionTo</strong>
                                       </p>
                                    }
                                    @if (HasKey(Model, "customerEmail") && !string.IsNullOrEmpty(Model?.customerEmail?.ToString()))
                                    {
                                       <p>@Model?.customerEmail</p>
                                    }
                                    @if (HasKey(Model, "customerMobileNumber") && !string.IsNullOrEmpty(Model?.customerMobileNumber?.ToString()))
                                    {
                                       <p>@Model?.customerMobileNumber</p>
                                    }
                                 </td>
                              }
                              @if (HasKey(Model?.label, "billingAddress") && !string.IsNullOrEmpty(Model?.label?.billingAddress?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">
                                       @Model?.label?.billingAddress
