                                       {
                                          <td class="text-left" style="max-width:150px;">
                                             @if (HasKey(tr?.stockDetails, "name") && !string.IsNullOrEmpty(tr?.stockDetails?.name?.ToString()))
                                             {
                                                <p>@tr?.stockDetails?.name</p>
                                             }
                                             else if (HasKey(tr, "accountName") && !string.IsNullOrEmpty(tr?.accountName?.ToString()))
                                             {
                                                <p>@tr?.accountName</p>
                                             }
                                             @if (HasKey(tr, "description") && tr?.description != tr?.stockDetails?.name && tr?.description != tr?.accountName && !string.IsNullOrEmpty(tr?.description?.ToString()))
