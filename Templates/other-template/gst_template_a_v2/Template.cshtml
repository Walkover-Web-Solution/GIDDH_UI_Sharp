                                    @if (HasKey(Model, "customerName") && !string.IsNullOrEmpty(Model?.customerName?.ToString()))
                                    {
                                       <p>@Model?.customerName</p>
                                    }
                                    @if (HasKey(Model, "billingAddress") && Model?.billingAddress != null)
                                    {
                                       @foreach (var address in Model?.billingAddress)
                                       {
                                          @if (!string.IsNullOrEmpty(address?.ToString()))
                                          {
                                             <p>@address</p>
                                          }
                                       }
                                    }
                                    @if (HasKey(Model, "billingState") && !string.IsNullOrEmpty(Model?.billingState?.ToString()))
                                    {
                                       <p>@Model?.billingState</p>
                                    }
                                 </td>
                              }
                              @if (HasKey(Model?.label, "shippingAddress") && !string.IsNullOrEmpty(Model?.label?.shippingAddress?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">
                                       @Model?.label?.shippingAddress
                                    </p>
                                    @if (HasKey(Model, "customerName") && !string.IsNullOrEmpty(Model?.customerName?.ToString()))
                                    {
                                       <p>@Model?.customerName</p>
                                    }
                                    @if (HasKey(Model, "shippingAddress") && Model?.shippingAddress != null)
                                    {
                                       @foreach (var address in Model?.shippingAddress)
                                       {
                                          @if (!string.IsNullOrEmpty(address?.ToString()))
                                          {
                                             <p>@address</p>
                                          }
                                       }
                                    }
                                    @if (HasKey(Model, "shippingState") && !string.IsNullOrEmpty(Model?.shippingState?.ToString()))
                                    {
                                       <p>@Model?.shippingState</p>
                                    }
                                 </td>
                              }
                           </tr>
                           <tr>
                              <td>
                                 @if (HasKey(Model?.label, "dueDate") && !string.IsNullOrEmpty(Model?.label?.dueDate?.ToString()))
                                 {
                                    <p class="font-11">@Model?.label?.dueDate</p>
                                    <p>@(HasKey(Model, "dueDate") ? Model?.dueDate : "")</p>
                                 }
                              </td>
                              @if (HasKey(Model?.label, "billingGstin") && !string.IsNullOrEmpty(Model?.label?.billingGstin?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">
                                       @Model?.label?.billingGstin
                                    </p>
                                    <p>@(HasKey(Model, "billingGstin") ? Model?.billingGstin : "")</p>
                                 </td>
                              }
                              @if (HasKey(Model?.label, "shippingGstin") && !string.IsNullOrEmpty(Model?.label?.shippingGstin?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">
                                       @Model?.label?.shippingGstin
                                    </p>
                                    <p>@(HasKey(Model, "shippingGstin") ? Model?.shippingGstin : "")</p>
                                 </td>
                              }
                           </tr>
                        </tbody>
                     </table>
                     <table class="meta">
                        <tbody>
                           <tr>
                              @if (HasKey(Model?.label, "shippingDate") && !string.IsNullOrEmpty(Model?.label?.shippingDate?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">@Model?.label?.shippingDate</p>
                                    <p>@(HasKey(Model, "shippingDate") ? Model?.shippingDate : "")</p>
                                 </td>
                              }
                              @if (HasKey(Model?.label, "shippedVia") && !string.IsNullOrEmpty(Model?.label?.shippedVia?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">@Model?.label?.shippedVia</p>
                                    <p>@(HasKey(Model, "shippedVia") ? Model?.shippedVia : "")</p>
                                 </td>
                              }
                              @if (HasKey(Model?.label, "trackingNumber") && !string.IsNullOrEmpty(Model?.label?.trackingNumber?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">@Model?.label?.trackingNumber</p>
                                    <p>@(HasKey(Model, "trackingNumber") ? Model?.trackingNumber : "")</p>
                                 </td>
                              }
                              @if (HasKey(Model?.label, "customField1") && !string.IsNullOrEmpty(Model?.label?.customField1?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">@Model?.label?.customField1</p>
                                    <p>@(HasKey(Model, "customField1") ? Model?.customField1 : "")</p>
                                 </td>
                              }
                              @if (HasKey(Model?.label, "customField2") && !string.IsNullOrEmpty(Model?.label?.customField2?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">@Model?.label?.customField2</p>
                                    <p>@(HasKey(Model, "customField2") ? Model?.customField2 : "")</p>
                                 </td>
                              }
                              @if (HasKey(Model?.label, "customField3") && !string.IsNullOrEmpty(Model?.label?.customField3?.ToString()))
                              {
                                 <td>
                                    <p class="font-11">@Model?.label?.customField3</p>
                                    <p>@(HasKey(Model, "customField3") ? Model?.customField3 : "")</p>
                                 </td>
                              }
                           </tr>
                        </tbody>
                     </table>
                  }
               </div>
               <div id="Template-table" @if (tableCount != 1) { <text>class="entryDiv"</text> }>
               <article>
                  <table class="item" cellpadding="0" cellspacing="0">
                     <thead>
                        <tr class="font-normal">
                           @if (HasKey(Model?.label, "sNo") && !string.IsNullOrEmpty(Model?.label?.sNo?.ToString()))
                           {
                              colspancount++;
                              <th class="text-left">@Model?.label?.sNo</th>
                           }
                           else
                           {
                              colspancount++;
                              <th class="text-left">S No.</th>
                           }
                           @if (HasKey(Model?.label, "date") && !string.IsNullOrEmpty(Model?.label?.date?.ToString()))
                           {
                              colspancount++;
                              <th class="text-left">@Model?.label?.date</th>
                           }
                           @if (HasKey(Model?.label, "item") && !string.IsNullOrEmpty(Model?.label?.item?.ToString()))
                           {
                              colspancount++;
                              <th class="text-left">@Model?.label?.item</th>
                           }
                           @if (HasKey(Model?.label, "hsnSac") && !string.IsNullOrEmpty(Model?.label?.hsnSac?.ToString()))
                           {
                              colspancount++;
                              <th class="text-right">@Model?.label?.hsnSac</th>
                           }
                           @if (HasKey(Model?.label, "quantity") && !string.IsNullOrEmpty(Model?.label?.quantity?.ToString()))
                           {
                              colspancount++;
                              <th class="text-right">@Model?.label?.quantity</th>
                           }
                           @if (HasKey(Model?.label, "rate") && !string.IsNullOrEmpty(Model?.label?.rate?.ToString()))
                           {
                              colspancount++;
                              <th class="text-right">@Model?.label?.rate</th>
                           }
                           @if (HasKey(Model?.label, "discount") && !string.IsNullOrEmpty(Model?.label?.discount?.ToString()))
                           {
                              colspancount++;
                              <th class="text-right">@Model?.label?.discount</th>
                           }
                           @if (HasKey(Model?.label, "taxableValue") && !string.IsNullOrEmpty(Model?.label?.taxableValue?.ToString()))
                           {
                              colspancount++;
                              <th class="text-right">@Model?.label?.taxableValue</th>
                           }
                           @if (HasKey(Model?.label, "taxes") && !string.IsNullOrEmpty(Model?.label?.taxes?.ToString()))
                           {
                              @if (HasKey(Model, "gstTaxesTotal") && Model?.gstTaxesTotal != null)
                              {
                                 @foreach (var tax in Model?.gstTaxesTotal)
                                 {
                                    colspancount++;
                                    <th class="text-right" style="text-transform: uppercase;">@(HasKey(tax, "name") ? tax?.name : "")</th>
                                 }
                              }
                           }
                           @if (HasKey(Model?.label, "total") && !string.IsNullOrEmpty(Model?.label?.total?.ToString()))
                           {
                              colspancount++;
                              <th colspan="2" class="text-right">@Model?.label?.total</th>
                           }
                        </tr>
                     </thead>
                     <tbody>
                        @if (HasKey(Model?.label, "previousDue") && !string.IsNullOrEmpty(Model?.label?.previousDue?.ToString()) && HasKey(Model, "previousDueAmount") && Model?.previousDueAmount != null)
                        {
                           <tr style="text-align: right;">
                              <td colspan="@colspancount">@Model?.label?.previousDue</td>
                              <td align="right">@Model?.previousDueAmount</td>
                           </tr>
                        }
                        @if (entryss != null)
                        {
                           @foreach (var entry in entryss)
                           {
                              @if (HasKey(entry, "transactions") && entry?.transactions != null)
                              {
                                 @foreach (var tr in entry?.transactions)
                                 {
                                    serial++;
                                    decimal distTotal = 0;
                                    string category = "other";
                                    decimal txTotal = 0;
                                    <tr>
                                       @if (HasKey(Model?.label, "sNo") && !string.IsNullOrEmpty(Model?.label?.sNo?.ToString()))
                                       {
                                          <td class="text-left">@serial</td>
