@using System.Collections.Generic;
@{
    // Helper function to check if key exists in dynamic object
    bool HasKey(dynamic obj, string propertyName)
    {
        try
        {
            if (obj == null) return false;
            var dict = (IDictionary<string, object>)obj;
            return dict.ContainsKey(propertyName);
        }
        catch
        {
            return false;
        }
    }
}
<!DOCTYPE html>
<html>
<head>
    <style type="text/css">
        table thead th, table tbody td { font-size: 12px; }
        table { table-layout: auto; }
        table.giddh-table { border: 1px solid #999999; border-collapse: collapse; }
        table.giddh-table td { padding: 2px 4px 2px 4px; border: 1px solid #999999; font-family: Arial, Helvetica, sans-serif; }
    </style>
</head>
<body>
    <table cellspacing="0" class="giddh-table" style="width:100%">
        <tbody>
            <tr>
                <td colspan="6" align="center" style="border-bottom: 0;">
                    <br/><b>Stock Report</b><br/>
                </td>
            </tr>
            <tr>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;"><strong>Stock Name</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;"><strong>Code</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;"><strong>Quantity</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;"><strong>Unit</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;"><strong>Rate</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;"><strong>Value</strong></td>
            </tr>
            @if (HasKey(Model, "stocks") && Model?.stocks != null)
            {
                @foreach (var stock in Model?.stocks)
                {
                    <tr>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;">@(HasKey(stock, "name") ? stock?.name : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;">@(HasKey(stock, "code") ? stock?.code : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;">@(HasKey(stock, "quantity") ? stock?.quantity : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;">@(HasKey(stock, "unit") ? stock?.unit : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;">@(HasKey(stock, "rate") ? stock?.rate : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999;">@(HasKey(stock, "value") ? stock?.value : "")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</body>
</html>
