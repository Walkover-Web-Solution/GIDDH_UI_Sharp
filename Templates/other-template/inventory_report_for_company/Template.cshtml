@using System.Collections.Generic;
@{
    // Helper function to check if key exists in dynamic object
    bool HasKey(dynamic obj, string propertyName)
    {
        try
        {
            if (obj == null) return false;
            var dict = (IDictionary<string, object>)obj;
            return dict.ContainsKey(propertyName);
        }
        catch
        {
            return false;
        }
    }
}
<!DOCTYPE html>
<html>
<head>
    <style type="text/css">
        table thead th, table tbody td {
            font-size: 12px;
        }
        table {
            table-layout: auto;
        }
        table.giddh-table {
            border: 1px solid #999999;
            border-collapse: collapse;
        }
        table.giddh-table td {
            padding: 2px 4px 2px 4px;
            border: 1px solid #999999;
            font-family: Arial, Helvetica, sans-serif;
        }
        table.giddh-table td.bdr-bottom-none {
            border: none !important;
        }
    </style>
</head>
<body>
    <table cellspacing="0" class="giddh-table" style="width:100%">
        <tbody>
            <tr>
                <td colspan="9" align="center" class="bdr-bottom-none" style="border-bottom: 0;">
                    <br/>
                    <b>Inventory Report for @(HasKey(Model?.company, "name") ? Model?.company?.name : "")</b>
                    <br/>
                </td>
            </tr>

            <tr>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;"><strong>Date</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;"><strong>Sender's Name</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;"><strong>Receiver's Name</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;"><strong>Product Name</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;"><strong>Qty</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;"><strong>Unit</strong></td>
                <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;"><strong>Description</strong></td>
            </tr>

            @if (HasKey(Model, "transactions") && Model?.transactions != null)
            {
                @foreach (var transaction in Model?.transactions)
                {
                    <tr>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;width:12%;">@(HasKey(transaction, "date") ? transaction?.date : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif;width:19%;">@(HasKey(transaction?.sender, "name") ? transaction?.sender?.name : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif; width:19%;">@(HasKey(transaction?.receiver, "name") ? transaction?.receiver?.name : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif; width:20%;">@(HasKey(transaction?.stock, "name") ? transaction?.stock?.name : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif; width:14%;">@(HasKey(transaction, "quantity") ? transaction?.quantity : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif; width:8%;">@(HasKey(transaction?.stockUnit, "code") ? transaction?.stockUnit?.code : "")</td>
                        <td style="padding: 2px 4px 2px 4px; border: 1px solid #999999; border-collapse: collapse; font-family:Arial, Helvetica, sans-serif; width:26%;">@(HasKey(transaction, "description") ? transaction?.description : "")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</body>
</html>
