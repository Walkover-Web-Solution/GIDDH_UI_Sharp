        .text-light { color:#7c7c7c!important; }
        .d-block { display:block; }
        .pr-3 { padding-right: 3px; }
        @@media print { table { page-break-after:auto } tr { page-break-inside:avoid; page-break-after:auto } td { page-break-inside:avoid; page-break-after:auto } thead { display:table-header-group } tfoot { display:table-footer-group } }
        .capitalize { text-transform:capitalize; }
        .pull-left { float: left; }
        .pull-right { float: right; }
        table { page-break-inside:auto }
        tr { page-break-inside:avoid; page-break-after:auto }
        thead { display:table-header-group }
        tfoot { display:table-footer-group }
    </style>
</head>
<body>
    <div class="content_wrap" id='body'>
        <div id="Template-header">
            <header>
                <table class="meta">
                    <tbody>
                        <tr>
                            <td>
                                @if (HasKey(Model, "companyName") && !string.IsNullOrEmpty(Model?.companyName?.ToString()))
                                {
                                    <h2>@Model?.companyName</h2>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </header>
        </div>

        @{
            int serial = 0;
        }

        <div id="Template-table" class="entryDiv">
            <article>
                <table class="item" id="product_table" cellpadding="0" cellspacing="0">
                    <thead>
                        <tr class="font-normal">
                            <th class="text-left">Item</th>
                            <th class="text-right">Quantity</th>
                            <th class="text-right">Rate</th>
                            <th class="text-right">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (HasKey(Model, "items") && Model?.items != null)
                        {
                            @foreach (var item in Model?.items)
                            {
                                serial++;
                                <tr>
                                    <td class="text-left">@(HasKey(item, "name") ? item?.name : "")</td>
                                    <td class="text-right">@(HasKey(item, "quantity") ? item?.quantity : "")</td>
                                    <td class="text-right">@(HasKey(item, "rate") ? item?.rate : "")</td>
                                    <td class="text-right">@(HasKey(item, "amount") ? item?.amount : "")</td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot>
                        <tr class="font-normal">
                            <th colspan="3" class="text-right">Total</th>
                            <th class="text-right">@(HasKey(Model, "grandTotal") ? Model?.grandTotal : "")</th>
                        </tr>
                    </tfoot>
                </table>
            </article>
        </div>

        <div style="width: 100%; display: block; float: none; overflow: hidden;" id='footerTable'>
            <table class="balance">
                <tr>
                    <th>Total In Words</th>
                    <td><span class="total-in-words">@(HasKey(Model, "totalInWords") ? Model?.totalInWords : "")</span></td>
                </tr>
            </table>
        </div>
    </div>
</body>
</html>
