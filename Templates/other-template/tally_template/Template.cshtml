        @@page { margin: 0; padding: 10.0px 10.0px 0; size: A4 portrait; @@top-center { content: element(pageHeader); } }
        @@media print { #lastRow { page-break-before: always !important; clear: both; } .page-break { page-break-before: always !important; clear: both; } #default table.item tfoot tr th, #default table.item th { position: relative; padding: 14px 10px; } #default footer { float: left; width: 100%; } #default header table { margin-top: 10px; } #default .subfooter { margin: 0 10.0px; width: 100%; } .content_wrap { position: relative; } }
