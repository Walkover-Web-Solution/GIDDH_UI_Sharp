        #hsnTable.hsn-table .item thead tr th, #hsnTable.hsn-table .item tfoot tr th { padding: 7px; }
        #hsnTable.hsn-table thead tr th:not(:last-child), #hsnTable.hsn-table tbody tr td:not(:last-child), #hsnTable.hsn-table tfoot tr th:not(:last-child) { border-right: 1px solid #262626; }
