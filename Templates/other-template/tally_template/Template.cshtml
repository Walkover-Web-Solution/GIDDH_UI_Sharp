        #default #Template-header .align-bottom { vertical-align: bottom !important; }
        #default article:after { clear: both; content: ""; display: table; }
        .text-center { text-align: center; }
        #default table.item { clear: both; width: 100%; table-layout: auto; }
        #default table.item tfoot tr th, #default table.item th { position: relative; padding: 14px 7px; font-weight: normal; text-transform: capitalize; background: #f2f3f4; border-bottom: 1px solid #262626; }
